{
  "name": "better-openclaw",
  "version": "1.0.24",
  "private": true,
  "description": "CLI tool, REST API, and web UI for scaffolding production-ready OpenClaw stacks",
  "author": "bachir@bidew.io",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bidewio/better-openclaw.git"
  },
  "homepage": "https://better-openclaw.dev",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@better-openclaw/web",
    "build:api": "turbo run build --filter=@better-openclaw/api",
    "build:mcp": "turbo run build --filter=@better-openclaw/mcp",
    "build:core": "turbo run build --filter=@better-openclaw/core",
    "build:all": "turbo run build --filter=@better-openclaw/web,@better-openclaw/api,@better-openclaw/mcp,@better-openclaw/mission-control,create-better-openclaw",
    "dev": "turbo run dev --filter=@better-openclaw/web --filter=@better-openclaw/api --filter=@better-openclaw/mission-control",
    "dev:web": "turbo run dev --filter=@better-openclaw/web",
    "dev:api": "turbo run dev --filter=@better-openclaw/api",
    "dev:mcp": "turbo run dev --filter=@better-openclaw/mcp",
    "dev:core": "turbo run dev --filter=@better-openclaw/core",
    "dev:all": "turbo run dev --filter=@better-openclaw/web,@better-openclaw/api,@better-openclaw/mcp,@better-openclaw/mission-control,create-better-openclaw",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "check": "biome check .",
    "clean": "turbo run clean",
    "video:dev": "pnpm --filter @better-openclaw/promo-video dev",
    "video:render": "pnpm --filter @better-openclaw/promo-video render:all",
    "video:prompts": "pnpm --filter @better-openclaw/promo-video generate:prompts",
    "check:all": "pnpm lint && pnpm typecheck && pnpm test",
    "check:deadcode": "knip",
    "check:markdown": "markdownlint-cli2 \"**/*.md\" \"**/*.mdx\"",
    "check:secrets": "detect-secrets scan --baseline .secrets.baseline",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "precommit": "pre-commit run --all-files",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.0",
    "knip": "^5.46.0",
    "markdownlint-cli2": "^0.18.1",
    "turbo": "^2.8.12",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}