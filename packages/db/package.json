{
    "name": "@better-openclaw/db",
    "version": "1.0.24",
    "private": false,
    "description": "Shared database client and schema for better-openclaw",
    "author": "bidew.io <bachir@bidew.io>",
    "license": "AGPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/bidewio/better-openclaw-db.git",
        "directory": "packages/db"
    },
    "homepage": "https://better-openclaw.dev",
    "packageManager": "pnpm@10.30.3",
    "sideEffects": false,
    "main": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "default": "./dist/index.mjs"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.mjs",
            "require": "./dist/*.cjs",
            "default": "./dist/*.mjs"
        }
    },
    "scripts": {
        "build": "tsdown",
        "build:tsc": "tsc",
        "lint": "biome check src/",
        "lint:fix": "biome check --write src/",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@better-auth/drizzle-adapter": "^1.5.4",
        "better-auth": "^1.5.4",
        "drizzle-orm": "^0.45.1",
        "postgres": "^3.4.8"
    },
    "devDependencies": {
        "@types/node": "^25.3.5",
        "drizzle-kit": "^0.31.9",
        "@biomejs/biome": "^2.4.6",
        "tsdown": "^0.21.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}