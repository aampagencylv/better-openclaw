{
  "name": "@better-openclaw/core",
  "version": "1.0.22",
  "private": false,
  "description": "Core logic for better-openclaw: schemas, service registry, resolver, composer, validators and generators",
  "author": "bidew.io <bachir@bidew.io>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bidewio/better-openclaw.git",
    "directory": "packages/core"
  },
  "homepage": "https://better-openclaw.dev",
  "packageManager": "pnpm@10.30.3",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs",
      "default": "./dist/*.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.3",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "openclaw",
    "docker-compose",
    "service-registry",
    "resolver",
    "composer",
    "ai-agent"
  ]
}