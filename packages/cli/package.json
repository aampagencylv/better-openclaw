{
  "name": "create-better-openclaw",
  "version": "1.0.0",
  "description": "CLI tool for scaffolding production-ready OpenClaw stacks with Docker Compose",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-better-openclaw": "./dist/index.js",
    "better-openclaw": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@better-openclaw/core": "workspace:*",
    "@clack/prompts": "^0.9.0",
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "docker",
    "docker-compose",
    "scaffolding",
    "cli",
    "ai-agent"
  ]
}
