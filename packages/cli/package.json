{
  "name": "create-better-openclaw",
  "version": "0.0.1",
  "description": "CLI tool for scaffolding production-ready OpenClaw stacks with Docker Compose",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "@better-openclaw/cli": "./dist/index.js",
    "create-better-openclaw": "./dist/index.js",
    "better-openclaw": "./dist/index.js",
    "better-openclaw-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@better-openclaw/core": "^1.0.2",
    "@clack/prompts": "^1.0.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "clawexa",
    "openclaw",
    "better-openclaw",
    "create-better-openclaw",
    "create-better-openclaw",
    "better-openclaw-cli",
    "docker",
    "docker-compose",
    "scaffolding",
    "cli",
    "ai-agent"
  ]
}
