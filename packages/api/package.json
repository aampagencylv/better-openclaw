{
  "name": "@better-openclaw/api",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for better-openclaw stack generation",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "default": "./dist/*.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:tsc": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production node dist/index.mjs",
    "start:windows": "NODE_ENV=production node dist/index.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@better-auth/infra": "^0.1.8",
    "@better-auth/passkey": "^1.5.2",
    "@better-openclaw/core": "workspace:*",
    "@better-openclaw/db": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "archiver": "^7.0.1",
    "better-auth": "^1.5.2",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.12.3",
    "ioredis": "^5.10.0",
    "postgres": "^3.4.7",
    "usesend-js": "^1.6.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "better-sqlite3": "^12.6.2",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}