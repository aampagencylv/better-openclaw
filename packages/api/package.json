{
  "name": "@better-openclaw/api",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for better-openclaw stack generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@better-openclaw/core": "^1.0.6",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.1",
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
